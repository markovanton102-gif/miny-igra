---
import { demoGameUrl } from '../config';

interface Props {
  title?: string;
  priority?: boolean;
}

const { title = 'Mines — демо', priority = false } = Astro.props;
---

{
  demoGameUrl ? (
    <div class="game-demo">
      <iframe
        title={title}
        src={demoGameUrl}
        allow="fullscreen"
        loading={priority ? 'eager' : 'lazy'}
      />
    </div>
  ) : (
    <p class="game-demo-missing">Демо временно недоступно.</p>
  )
}
