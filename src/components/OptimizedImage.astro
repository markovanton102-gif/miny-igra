---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const { src, alt, width, height, loading = 'lazy', fetchpriority, class: className } = Astro.props;
const base = src.replace(/\.(png|jpe?g|webp)$/i, '');
const webpSrc = `${base}.webp`;
const fallbackSrc = src.includes('.') ? src : `${src}.png`;
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={fallbackSrc}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
    decoding="async"
  />
</picture>
