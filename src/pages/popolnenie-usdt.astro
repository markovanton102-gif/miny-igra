---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PlayButton from '../components/PlayButton.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const metaDescription =
  'Пополнение Mines через USDT и криптовалюту: депозит в казино, сети TRC20/ERC20 и запуск игры мины онлайн.';

const breadcrumbs = [
  { name: 'Главная', path: '/' },
  { name: 'Пополнение USDT', path: '/popolnenie-usdt/' },
];
---

<BaseLayout
  title="Мины — пополнение USDT"
  description={metaDescription}
  breadcrumbs={breadcrumbs}
>
  <PageHero
    title="Mines — пополнение USDT"
    lead="Криптодепозит часто проходит быстрее, когда карты блокируют платежи. Проверяйте сеть и адрес в кассе."
  />
  <article class="content">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />

      <p class="article-lead">
        <strong>Mines пополнение USDT</strong> удобно тем, кто уже держит стейблкоины на бирже или в кошельке. После
        зачисления баланса в казино ищите <strong>Mines+</strong> так же, как после депозита картой.
      </p>

      <h2>Депозит USDT для игры в Mines</h2>
      <ol>
        <li>Выберите оператора на странице <a href="/gde-igrat/">где играть</a>.</li>
        <li>В кассе выберите USDT (или Bitcoin, если USDT недоступен).</li>
        <li>Скопируйте адрес и <strong>сеть</strong> (TRC20, ERC20 и т.д.) — ошибка сети = потеря средств.</li>
        <li>Отправьте сумму не ниже минимума, дождитесь подтверждений в блокчейне.</li>
        <li>Откройте Mines в каталоге instant-игр.</li>
      </ol>

      <h2>Плюсы и риски криптодепозита</h2>
      <ul>
        <li>часто выше лимиты и быстрее зачисление;</li>
        <li>нужна внимательность к сети и комиссии;</li>
        <li>курс и конвертация — по правилам казино.</li>
      </ul>
      <p>
        Другие способы: <a href="/popolnenie-kartoy/">карта</a>,
        <a href="/popolnenie-qiwi/">QIWI</a>. Сначала <a href="/demo/">демо</a> и
        <a href="/kak-igrat/">правила Mines</a>. 18+.
      </p>

      <p><PlayButton /></p>
    </div>
  </article>
</BaseLayout>
