---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PlayButton from '../components/PlayButton.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
---

<BaseLayout
  title="Мины — отзывы игроков"
  description="Отзывы о игре Mines: опыт игроков, плюсы и минусы, честность механики."
>
  <PageHero
    title="Отзывы о игре Mines"
    lead="Собираем типичные мнения игроков: быстрые раунды, контроль вывода и риск «взрыва» на последней ячейке."
  />
  <article class="content">
    <div class="container">
      <h2>Что хвалят</h2>
      <ul>
        <li>Понятные правила без сложных линий выплат</li>
        <li>Можно играть с телефона в браузере</li>
        <li>Короткие сессии — удобно для перерыва</li>
      </ul>
      <h2>На что жалуются</h2>
      <ul>
        <li>Высокий риск при жадности — забирают слишком поздно</li>
        <li>Нужна дисциплина по банкроллу</li>
      </ul>

      <ReviewsSection />

      <p><PlayButton /></p>
    </div>
  </article>
</BaseLayout>
