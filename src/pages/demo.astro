---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PlayButton from '../components/PlayButton.astro';
import GameDemo from '../components/GameDemo.astro';
---

<BaseLayout
  title="Mines — демо бесплатно"
  description="Mines демо: играть бесплатно, потренироваться без депозита."
>
  <PageHero
    title="Mines — демо-режим"
    lead="Играйте бесплатно прямо на странице. На реальные деньги переходите только с готовым лимитом по банкроллу."
  />
  <article class="content">
    <div class="container">
      <GameDemo title="Mines+" />

      <p>
        В демо можно отработать, сколько ячеек открывать за раунд, без риска для баланса.
      </p>
      <p><PlayButton /></p>
    </div>
  </article>
</BaseLayout>
