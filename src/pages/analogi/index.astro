---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PlayButton from '../../components/PlayButton.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AnalogGrid, { type AnalogSection } from '../../components/AnalogGrid.astro';

const breadcrumbs = [
  { name: 'Главная', path: '/' },
  { name: 'Аналоги Mines', path: '/analogi/' },
];

const metaDescription =
  'Аналоги Mines (мины): Aviator, Spaceman, Pilot, Plinko, Chicken Rush — instant и crash-игры. Сравнение с мины онлайн.';

const analogSections: AnalogSection[] = [
  {
    id: 'analog-crash-heading',
    heading: 'Crash — другой тип риска',
    lead: 'Множитель растёт сам — одна кнопка «забрать» до вылета. Не поле с ячейками, как в Mines, но тот же темп сессии.',
    items: [
      {
        href: '/analogi/aviator/',
        title: 'Aviator',
        tag: 'Crash',
        icon: '✈️',
        variant: 'crash',
        desc: 'Самолёт и cash out — классика crash. Самый узнаваемый аналог мины в поиске.',
      },
      {
        href: '/analogi/spaceman/',
        title: 'Spaceman',
        tag: 'Crash',
        icon: '🚀',
        variant: 'crash',
        desc: 'Космонавт, растущий коэффициент. Напряжение «ещё секунда» — как при жадности в минах.',
      },
      {
        href: '/analogi/pilot/',
        title: 'Pilot',
        tag: 'Crash',
        icon: '🛩️',
        variant: 'crash',
        desc: 'Пилот краш в СНГ. Та же схема вывода до обрыва раунда.',
      },
    ],
  },
  {
    id: 'analog-instant-heading',
    heading: 'Instant — без crash-вылета',
    lead: 'Другая механика случайности: шарик или пошаговый риск вместо сетки 5×5.',
    items: [
      {
        href: '/analogi/plinko/',
        title: 'Plinko',
        tag: 'Instant',
        icon: '🎯',
        variant: 'instant',
        desc: 'Шарик по кеглям — множитель в слоте внизу. Один запуск, результат сразу.',
      },
      {
        href: '/analogi/chicken-rush/',
        title: 'Chicken Rush',
        tag: 'Instant',
        icon: '🐔',
        variant: 'instant',
        desc: 'Трендовая instant с простыми правилами. Другой сеттинг после Mines+.',
      },
    ],
  },
];
---

<BaseLayout title="Аналоги Mines" description={metaDescription} breadcrumbs={breadcrumbs}>
  <PageHero
    showPlayButton={false}
    title="Аналоги игры Mines"
    lead="Выберите игру — карточка целиком ведёт на обзор: отличия от мин и когда переключиться имеет смысл."
  />
  <article class="content content--analogi">
    <div class="container">
      <Breadcrumbs items={breadcrumbs} />

      <p class="article-lead">
        <strong>Аналоги Mines</strong> (мины) — crash и instant из того же каталога казино. Нажмите на карточку для обзора
        каждой альтернативы или вернитесь к <a href="/kak-igrat/">правилам Mines</a>.
      </p>

      <AnalogGrid sections={analogSections} />

      <h2>Где играть в аналоги</h2>
      <p>
        Те же площадки, что и для мин: раздел instant-игр, поиск по названию. Список — на странице{' '}
        <a href="/gde-igrat/">где играть</a>. Перед депозитом — <a href="/demo/">демо Mines</a> и{' '}
        <a href="/otzyvy/">отзывы</a>. 18+, ответственная игра.
      </p>

      <p class="analog-footer-links">
        Вернуться к <a href="/">Mines</a> · <a href="/demo/">демо</a> · <a href="/gde-igrat/">где играть</a>
        <span class="analog-age">18+</span>
      </p>

      <p><PlayButton /></p>
    </div>
  </article>
</BaseLayout>
